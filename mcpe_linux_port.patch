diff -ruN handheld2/src/main_linux.h handheld/src/main_linux.h
--- handheld2/src/main_linux.h	1970-01-01 09:00:00.000000000 +0900
+++ handheld/src/main_linux.h	2026-03-03 12:07:43.910251875 +0900
@@ -0,0 +1,157 @@
+#ifndef MAIN_LINUX_H__
+#define MAIN_LINUX_H__
+
+#include <cassert>
+#include <fstream>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <unistd.h>
+#include <png.h>
+
+#include <SDL/SDL.h>
+
+#include "App.h"
+#include "AppConstants.h"
+#include "AppPlatform.h"
+#include "platform/input/Mouse.h"
+#include "platform/input/Multitouch.h"
+#include "platform/input/Keyboard.h"
+
+static void png_readCallback(png_structp pngPtr, png_bytep data, png_size_t length) {
+    ((std::istream*)png_get_io_ptr(pngPtr))->read((char*)data, length);
+}
+
+class AppPlatform_linux : public AppPlatform {
+public:
+
+    TextureData loadTexture(const std::string& filename_, bool textureFolder) {
+        TextureData out;
+        std::string filename = textureFolder ? "data/images/" + filename_ : filename_;
+        std::ifstream source(filename.c_str(), std::ios::binary);
+        fprintf(stderr, "LOADING: %s (exists=%d)\n", filename.c_str(), (bool)source);
+        if (!source) { fprintf(stderr, "FILE NOT FOUND: %s\n", filename.c_str()); return out; } fprintf(stderr, "FILE FOUND: %s\n", filename.c_str());
+        png_structp pngPtr = png_create_read_struct(PNG_LIBPNG_VER_STRING, NULL, NULL, NULL);
+        if (!pngPtr) return out;
+        png_infop infoPtr = png_create_info_struct(pngPtr);
+        if (!infoPtr) { png_destroy_read_struct(&pngPtr, NULL, NULL); return out; }
+        png_set_read_fn(pngPtr, (void*)&source, png_readCallback);
+        png_read_info(pngPtr, infoPtr);
+        out.w = png_get_image_width(pngPtr, infoPtr);
+        out.h = png_get_image_height(pngPtr, infoPtr);
+        png_bytep* rowPtrs = new png_bytep[out.h];
+        out.data = new unsigned char[4 * out.w * out.h];
+        out.memoryHandledExternally = false;
+        for (int i = 0; i < out.h; i++)
+            rowPtrs[i] = (png_bytep)&out.data[i * 4 * out.w];
+        png_read_image(pngPtr, rowPtrs); fprintf(stderr, "PNG READ: %s %dx%d\n", filename.c_str(), out.w, out.h);
+        png_destroy_read_struct(&pngPtr, &infoPtr, NULL);
+        delete[] rowPtrs;
+        return out;
+    }
+};
+
+static int g_width  = 854;
+static int g_height = 480;
+
+static unsigned char transformKey(int key) {
+    if (key == SDLK_LSHIFT)  return Keyboard::KEY_LSHIFT;
+    if (key == SDLK_DOWN)    return 40;
+    if (key == SDLK_UP)      return 38;
+    if (key == SDLK_SPACE)   return Keyboard::KEY_SPACE;
+    if (key == SDLK_RETURN)  return 13;
+    if (key == SDLK_ESCAPE)  return Keyboard::KEY_ESCAPE;
+    if (key == SDLK_TAB)     return 250;
+    if (key >= 'a' && key <= 'z') return key - 32;
+    if (key >= SDLK_0 && key <= SDLK_9) return '0' + (key - SDLK_0);
+    return 0;
+}
+
+static int handleEvents() {
+    SDL_Event event;
+    while (SDL_PollEvent(&event)) {
+        switch (event.type) {
+        case SDL_QUIT: return -1;
+        case SDL_KEYDOWN: { unsigned char k = transformKey(event.key.keysym.sym); if (k) Keyboard::feed(k, 1); break; }
+        case SDL_KEYUP:   { unsigned char k = transformKey(event.key.keysym.sym); if (k) Keyboard::feed(k, 0); break; }
+        case SDL_MOUSEBUTTONDOWN:
+            if (event.button.button == SDL_BUTTON_WHEELUP)
+                Mouse::feed(3, 0, event.button.x, event.button.y, 0, 1);
+            else if (event.button.button == SDL_BUTTON_WHEELDOWN)
+                Mouse::feed(3, 0, event.button.x, event.button.y, 0, -1);
+            else {
+                char btn = (event.button.button == SDL_BUTTON_LEFT) ? 1 : 2;
+                Mouse::feed(btn, 1, event.button.x, event.button.y);
+                Multitouch::feed(btn, 1, event.button.x, event.button.y, 0);
+            }
+            break;
+        case SDL_MOUSEBUTTONUP: {
+            char btn = (event.button.button == SDL_BUTTON_LEFT) ? 1 : 2;
+            Mouse::feed(btn, 0, event.button.x, event.button.y);
+            Multitouch::feed(btn, 0, event.button.x, event.button.y, 0);
+            break;
+        }
+        case SDL_MOUSEMOTION:
+            Mouse::feed(0, 0, event.motion.x, event.motion.y, event.motion.xrel, event.motion.yrel);
+            Multitouch::feed(0, 0, event.motion.x, event.motion.y, 0);
+            break;
+        default: break;
+        }
+    }
+    return 0;
+}
+
+int main(int argc, char** argv) {
+    if (SDL_Init(SDL_INIT_VIDEO) < 0) {
+        fprintf(stderr, "Couldn't initialize SDL: %s\n", SDL_GetError());
+        return -1;
+    }
+
+    // Просим SDL создать OpenGL контекстvirtual bool supportsTouchscreen() { return true; } — gl4es его перехватит
+    SDL_GL_SetAttribute(SDL_GL_RED_SIZE,   8);
+    SDL_GL_SetAttribute(SDL_GL_GREEN_SIZE, 8);
+    SDL_GL_SetAttribute(SDL_GL_BLUE_SIZE,  8);
+    SDL_GL_SetAttribute(SDL_GL_DEPTH_SIZE, 16);
+    SDL_GL_SetAttribute(SDL_GL_DOUBLEBUFFER, 1);
+
+    SDL_Surface* screen = SDL_SetVideoMode(g_width, g_height, 32, SDL_OPENGL | SDL_RESIZABLE);
+    if (!screen) {
+        fprintf(stderr, "Couldn't create SDL window: %s\n", SDL_GetError());
+        return -2;
+    }
+    SDL_WM_SetCaption(APP_NAME, NULL);
+
+    if (argc > 0) {
+        std::string path = argv[0];
+        size_t e = path.rfind('/');
+        if (e != std::string::npos) { path = path.substr(0, e); chdir(path.c_str()); }
+    }
+
+    // AppContext без EGL — используем NO_EGL стиль, просто передаём платформу
+    AppContext context;
+    AppPlatform_linux platform;
+    context.platform = &platform;
+    context.doRender = true;
+    // display/context/surface не используются — swapBuffers делает SDL
+
+    MAIN_CLASS* app = new MAIN_CLASS();
+    std::string home = getenv("HOME") ? getenv("HOME") : ".";
+    app->externalStoragePath      = home + "/.minecraft/";
+    app->externalCacheStoragePath = home + "/.minecraft/";
+    if (argc > 1) { int port = atoi(argv[1]); if (port) app->commandPort = port; }
+
+    app->App::init(context);
+    app->setSize(g_width, g_height);
+
+    while (!app->wantToQuit()) {
+        if (handleEvents() != 0) break;
+        app->update();
+        SDL_GL_SwapBuffers();  // вместо eglSwapBuffers
+    }
+
+    SDL_Quit();
+    delete app;
+    return 0;
+}
+
+#endif /* MAIN_LINUX_H__ */
